{
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "crons": [
    { "path": "/api/facebook-auto-post", "schedule": "0 9 * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
